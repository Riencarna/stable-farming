# ============================================
# Stable Farming - 환경 변수 설정
# ============================================
# 이 파일을 .env 로 복사한 후 값을 입력하세요
# cp .env.example .env

# --- 텔레그램 설정 (필수) ---
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# --- 알림 조건 ---
MIN_APR=8.0

# --- 모니터링 간격 (분) ---
SCAN_INTERVAL_MINUTES=10

# --- Binance API (선택) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Bybit API (선택) ---
BYBIT_API_KEY=
BYBIT_API_SECRET=

# --- OKX API (선택) ---
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# --- Gate.io API (선택) ---
GATEIO_API_KEY=
GATEIO_API_SECRET=

# --- KuCoin API (선택) ---
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_PASSPHRASE=

# --- HTX API (선택) ---
HTX_API_KEY=
HTX_API_SECRET=
